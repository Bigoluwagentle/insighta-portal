<%- include('header', { title: profile.name }) %>

<div class="page-header">
  <a href="/profiles" class="btn btn-secondary">← Back</a>
  <h2><%= profile.name %></h2>
</div>

<div class="detail-card">
  <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value"><%= profile.id %></span></div>
  <div class="detail-row"><span class="detail-label">Gender</span><span class="detail-value"><%= profile.gender %> (<%= (profile.gender_probability * 100).toFixed(1) %>%)</span></div>
  <div class="detail-row"><span class="detail-label">Age</span><span class="detail-value"><%= profile.age %></span></div>
  <div class="detail-row"><span class="detail-label">Age Group</span><span class="detail-value"><span class="badge badge-<%= profile.age_group %>"><%= profile.age_group %></span></span></div>
  <div class="detail-row"><span class="detail-label">Country</span><span class="detail-value"><%= profile.country_name || '—' %> (<%= profile.country_id %>)</span></div>
  <div class="detail-row"><span class="detail-label">Country Probability</span><span class="detail-value"><%= (profile.country_probability * 100).toFixed(1) %>%</span></div>
  <div class="detail-row"><span class="detail-label">Created</span><span class="detail-value"><%= new Date(profile.created_at).toLocaleString() %></span></div>
</div>

<%- include('footer') %>
